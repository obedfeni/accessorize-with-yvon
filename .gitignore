# ==========================================
# .gitignore for Retro Jersey Shop
# ==========================================

# Environment Variables - NEVER COMMIT THESE!
.env
.env.local
.env.production
*.env

# Google Service Account Credentials
credentials.json
service-account.json
*-credentials.json
gcp-*.json

# Streamlit Secrets
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# OS Files
Thumbs.db
.DS_Store

# Temporary files
*.tmp
temp/
tmp/

# Backup files
*.bak
*.backup
